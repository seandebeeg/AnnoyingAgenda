<Page x:Class="AnnoyingAgenda.Client.ListEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnnoyingAgenda.Client"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListEditor"
      Loaded="Page_Loaded">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5*"/>
      <ColumnDefinition Width="2*"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0" x:Name="TaskPanel">
      
    </StackPanel>

    <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center">
      <Button Style="{StaticResource WindowButtonTriggers}" Width="75" Height="50" Margin="0,0,20,10" Foreground="White" VerticalAlignment="Bottom" HorizontalAlignment="Left" Content="Save" Background="LightGreen"/>
      <Button Style="{StaticResource WindowButtonTriggers}" Width="75" Height="50" Margin="20,0,0,10" Foreground="White" VerticalAlignment="Bottom" HorizontalAlignment="Right" Content="Quit" Background="Red" Click="QuitButton"/>
    </StackPanel>
    <Border Grid.Column="1" BorderBrush="LightGray" CornerRadius="10" BorderThickness="1" Margin="0,0,10,3">
      <StackPanel VerticalAlignment="Center" Margin="0,0,0,40" CanVerticallyScroll="True">
        <Button Style="{StaticResource WindowButtonTriggers}" Content="New Event" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" Content="Delete Event" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" Content="Edit Event" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" Content="Search" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Button Style="{StaticResource WindowButtonTriggers}" Height="40" Width="60" Margin="0,0,15,0" Background="LightGray" ToolTip="Undo">
            <Image Source="/Assets/Buttons/AnnoyingAgenda-Button-Undo.png"/>
          </Button>
          <Button Style="{StaticResource WindowButtonTriggers}" Height="40" Width="60" Margin="15,0,0,0" Background="LightGray" ToolTip="Redo">
            <Image Source="/Assets/Buttons/AnnoyingAgenda-Button-Redo.png"/>
          </Button>
        </StackPanel>
      </StackPanel>
    </Border>

  </Grid>
</Page>
  