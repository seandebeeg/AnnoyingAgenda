<Page x:Class="AnnoyingAgenda.Client.ListEditor"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnnoyingAgenda.Client"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListEditor"
      Loaded="Page_Loaded">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="5*"/>
      <ColumnDefinition Width="2*"/>
    </Grid.ColumnDefinitions>

    <Popup Height="300" Width="450" IsOpen="False" Placement="Center" x:Name="NewEventPopup" StaysOpen="True" Panel.ZIndex="2">
      <Border BorderBrush="LightGray" BorderThickness="3" Background="White">
        <StackPanel>
          <TextBlock Text="Event Name" HorizontalAlignment="Center" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <TextBox  x:Name="EventNameBox" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="Tw Cen MT Condensed" FontSize="20"/>
          <TextBlock Text="Reminder Date" HorizontalAlignment="Center" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <DatePicker FontFamily="Tw Cen MT Condensed" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Height="30" FontSize="20" x:Name="EventDatePicker"></DatePicker>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Hour" FontFamily="Tw Cen MT Condensed" FontSize="30"/>
            <ComboBox x:Name="HourSelector" FontFamily="Tw Cen MT" FontSize="30" Height="40" Width="120"></ComboBox>
            <TextBlock Text="Minute" FontFamily="Tw Cen MT Condensed" FontSize="30" Margin="20,0,0,0"/>
            <ComboBox x:Name="MinuteSelector" FontFamily="Tw Cen MT" FontSize="30" Height="40" Width="120"></ComboBox>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Create" Click="CreateEvent" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,10,0" Style="{StaticResource WindowButtonTriggers}" Width="50"  Height="30" Background="LightGray"/>
            <Button Content="Cancel" Click="CancelNewEventClick" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource WindowButtonTriggers}" Width="50"  Height="30" Background="LightGray"/>
          </StackPanel>
          
        </StackPanel>
      </Border>
    </Popup>

    <Popup Height="300" Width="450" IsOpen="False" Placement="Center" x:Name="EditEventPopup" StaysOpen="True">
      <Border BorderBrush="LightGray" BorderThickness="3" Background="White">
        <StackPanel>
          <TextBlock Text="Event Name" HorizontalAlignment="Center" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <TextBox  x:Name="EditNameBox" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="Tw Cen MT Condensed" FontSize="20"/>
          <TextBlock Text="Reminder Date" HorizontalAlignment="Center" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <DatePicker FontFamily="Tw Cen MT Condensed" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Height="30" FontSize="20" x:Name="EditDatePicker"></DatePicker>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="Hour" FontFamily="Tw Cen MT Condensed" FontSize="30"/>
            <ComboBox x:Name="EditHourSelector" FontFamily="Tw Cen MT" FontSize="30" Height="40" Width="120"></ComboBox>
            <TextBlock Text="Minute" FontFamily="Tw Cen MT Condensed" FontSize="30" Margin="20,0,0,0"/>
            <ComboBox x:Name="EditMinuteSelector" FontFamily="Tw Cen MT" FontSize="30" Height="40" Width="120"></ComboBox>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Save" Click="ConfirmEdit" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,10,0" Style="{StaticResource WindowButtonTriggers}" Width="50"  Height="30" Background="LightGray"/>
            <Button Content="Cancel" Click="CancelEditClick" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource WindowButtonTriggers}" Width="50"  Height="30" Background="LightGray"/>
          </StackPanel>

        </StackPanel>
      </Border>
    </Popup>

    <Popup Height="400" Width="600" Placement="Center" x:Name="SearchPopup" StaysOpen="True" IsOpen="False">
      <Border BorderBrush="LightGray" BorderThickness="3" Background="White">
        <StackPanel>
          <TextBlock Text="Search Term" HorizontalAlignment="Center" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <TextBox x:Name="SearchBox" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="30" FontSize="30" FontFamily="Tw Cen MT Condensed"/>
          <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
            <Button Content="Search" Click="SearchForEvents" HorizontalAlignment="Center" Height="30" Width="50" Background="LightGray" Style="{StaticResource WindowButtonTriggers}" Margin="0,0,10,10"/>
            <Button Content="Exit" Click="CancelSearchClick" HorizontalAlignment="Center" Height="30" Width="50" Background="LightGray" Style="{StaticResource WindowButtonTriggers}" Margin="10,0,0,10"/>
          </StackPanel>
          <ScrollViewer VerticalScrollBarVisibility="Auto" CanContentScroll="True">
            <StackPanel x:Name="SearchResultPanel" CanVerticallyScroll="True"></StackPanel>
          </ScrollViewer>
        </StackPanel>
      </Border>
    </Popup>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Grid.Column="0" x:Name="TaskPanel" CanVerticallyScroll="True"></StackPanel>
    </ScrollViewer>
   

    <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center">
      <Button Style="{StaticResource WindowButtonTriggers}" Width="75" Height="50" Margin="0,0,20,10" Foreground="White" VerticalAlignment="Bottom" HorizontalAlignment="Left" Content="Save" Background="LightGreen" Click="SaveClick"/>
      <Button Style="{StaticResource WindowButtonTriggers}" Width="75" Height="50" Margin="20,0,0,10" Foreground="White" VerticalAlignment="Bottom" HorizontalAlignment="Right" Content="Quit" Background="Red" Click="QuitButton"/>
    </StackPanel>
    <Border Grid.Column="1" BorderBrush="LightGray" CornerRadius="10" BorderThickness="1" Margin="0,0,10,3">
      <StackPanel VerticalAlignment="Center" Margin="0,0,0,40" CanVerticallyScroll="True">
        <Button Style="{StaticResource WindowButtonTriggers}" Content="New Event" Click="NewEventButton" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" x:Name="DeleteButton"  Content="Delete Event" Click="ToggleDeletionMode" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" x:Name="EditButton" Content="Edit Event" Click="ToggleEditMode" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
        <Button Style="{StaticResource WindowButtonTriggers}" Content="Search" Click="SearchClick" FontFamily="Tw Cen MT Condensed" FontSize="40" Height="40" Width="150" Background="LightGray" Margin="0,0,0,10" MouseEnter="MouseOverAnimation" MouseLeave="MouseLeaveAnimation"/>
      </StackPanel>
    </Border>
  </Grid>
</Page>
  