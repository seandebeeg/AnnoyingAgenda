<Page x:Class="AnnoyingAgenda.Client.MainMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnnoyingAgenda.Client"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainMenu">

    <Grid>
    <Border Grid.Row="1" BorderBrush="LightGray" CornerRadius="10" BorderThickness="1">
      <Grid>
        <TextBlock Text="Welcome" HorizontalAlignment="Center" FontSize="50" FontWeight="UltraBold" FontFamily="Tw Cen MT Condensed"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Button Height="100" Width="200" HorizontalAlignment="Right" Content="Settings" FontSize="30" FontWeight="UltraBold" FontFamily="Tw Cen MT Condensed" Margin="0,0,20,0" Style="{StaticResource WindowButtonTriggers}" Background="LightGray"/>
          <Button Height="100" Width="200" HorizontalAlignment="Left" Content="Lists" FontSize="30" FontWeight="UltraBold" FontFamily="Tw Cen MT Condensed" Margin="20,0,0,0" Style="{StaticResource WindowButtonTriggers}" Background="LightGray"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
