<Page x:Class="AnnoyingAgenda.Client.MainMenu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnnoyingAgenda.Client"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainMenu">

  <Grid>
    <Grid>
      <TextBlock Text="Welcome" HorizontalAlignment="Center" FontSize="50" FontFamily="Segoe UI"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Border BorderBrush="#e5e5e5" BorderThickness="3" CornerRadius="5" Margin="0,0,25,0" Height="75" Width="150">
          <Button  HorizontalAlignment="Stretch" Content="Lists" FontSize="30" FontFamily="Segoe UI"  Style="{StaticResource WindowButtonTriggers}" Background="#fbfbfb" Click="ListsClick" Foreground="#292929"/>
        </Border>
        <Border BorderBrush="#e5e5e5" BorderThickness="3" CornerRadius="5" Margin="25,0,0,0" Height="75" Width="150">
          <Button Height="75" Width="150" HorizontalAlignment="Stretch" Content="Settings" FontSize="30" FontFamily="Segoe UI" Style="{StaticResource WindowButtonTriggers}" Background="#fbfbfb" Click="SettingsClick" Foreground="#292929"/>
        </Border>
      </StackPanel>
    </Grid>
  </Grid>
</Page>
