<Page x:Class="AnnoyingAgenda.Client.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AnnoyingAgenda.Client"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Settings">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="55"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="50"/>
    </Grid.RowDefinitions>
    <TextBlock Text="Settings" Height="75" FontSize="40" FontFamily="Segoe UI" HorizontalAlignment="Center" Grid.Row="0"/>

    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Visible">
      <StackPanel CanVerticallyScroll="True">
        <TextBlock Text="Service" FontFamily="Segoe UI" FontSize="20"/>
        <ListView x:Name="SettingsList" VerticalAlignment="Stretch" ScrollViewer.VerticalScrollBarVisibility="Auto" BorderBrush="Transparent" Margin="10,0,0,0" Background="#f3f3f3">
          <ListView.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <CheckBox IsChecked="{Binding IsEnabled}"/>
                <TextBlock Text="{Binding Name}" Margin="5,0,0,0" FontFamily="Segoe UI" FontSize="15"/>
              </StackPanel>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>
    </ScrollViewer>
    <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Center">
      <Border Width="120" Height="30" Margin="20,0,20,0" BorderThickness="3" CornerRadius="5" BorderBrush="#e5e5e5">
        <Button Content="Save Settings" 
          Click="SaveSettings" 
          Style="{StaticResource WindowButtonTriggers}"
          Background="#fbfbfb" Foreground="#292929"
          FontFamily="Segoe UI" FontSize="15"/>
      </Border>
      <Border Width="120" Height="30" Margin="20,0,0,0" BorderThickness="3" CornerRadius="5" BorderBrush="#e5e5e5">
        <Button Content="Back To Main Menu"
          Click="MainMenuClick" 
          Style="{StaticResource WindowButtonTriggers}" 
          Background="#fbfbfb" Foreground="#292929"
          FontFamily="Segoe UI" FontSize="13"/>
      </Border>
    </StackPanel>
  </Grid>
</Page>
